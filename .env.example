# Apify API configuration
APIFY_TOKEN=your_apify_api_token_here
APIFY_MAX_RETRIES=3
APIFY_TIMEOUT_SECONDS=300
APIFY_MAX_CONCURRENCY=5

# Job search configuration
JOB_KEYWORDS=Data Engineer
