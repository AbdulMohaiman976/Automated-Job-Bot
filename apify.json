{
  "name": "data-engineering-job-scraper",
  "title": "Data Engineering Job Scraper",
  "description": "Scrapes remote Data Engineering jobs from Indeed and ZipRecruiter",
  "version": "0.1.0",
  "buildTag": "latest",
  "env": {
    "APIFY_COMMIT_SHA": null,
    "APIFY_IS_AT_HOME": true
